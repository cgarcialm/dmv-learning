[
  {
    "lesson_id": "lesson_right_of_way_basics",
    "topic_ids": [
      "right_of_way"
    ],
    "title": "Right-of-Way Basics",
    "segments": [
      {
        "segment_id": "lesson_right_of_way_basics_segment_1",
        "text": "Right-of-way is about preventing conflicts, not forcing your turn. When another road user is legally or practically in your path, yield until the movement is safe.",
        "source_ids": [
          "ca-dmv-handbook-section-6-navigating-roads",
          "ca-dmv-sample-test-2",
          "ca-dmv-handbook-section-7-laws-road",
          "ca-dmv-sample-test-1"
        ]
      },
      {
        "segment_id": "lesson_right_of_way_basics_segment_2",
        "text": "Left turns are a common test topic: if an approaching vehicle is close enough to be dangerous, wait before completing the turn.",
        "source_ids": [
          "ca-dmv-handbook-section-6-navigating-roads",
          "ca-dmv-sample-test-2",
          "ca-dmv-handbook-section-7-laws-road",
          "ca-dmv-sample-test-1"
        ]
      },
      {
        "segment_id": "lesson_right_of_way_basics_segment_3",
        "text": "Pedestrians and people using mobility devices in crosswalks require extra caution. Stay stopped until they are safely clear of your vehicle's path.",
        "source_ids": [
          "ca-dmv-handbook-section-6-navigating-roads",
          "ca-dmv-sample-test-2",
          "ca-dmv-handbook-section-7-laws-road",
          "ca-dmv-sample-test-1"
        ]
      }
    ],
    "rule_ids": [
      "right_of_way_left_turn_oncoming",
      "right_of_way_crosswalk_mobility_device",
      "right_of_way_highway_traffic"
    ],
    "source_ids": [
      "ca-dmv-handbook-section-6-navigating-roads",
      "ca-dmv-sample-test-2",
      "ca-dmv-handbook-section-7-laws-road",
      "ca-dmv-sample-test-1"
    ],
    "review_status": "draft"
  },
  {
    "lesson_id": "lesson_signs_signals_basics",
    "topic_ids": [
      "signs_signals"
    ],
    "title": "Signs and Signals Basics",
    "segments": [
      {
        "segment_id": "lesson_signs_signals_basics_segment_1",
        "text": "Signals and markings tell you what action is allowed or required before you move.",
        "source_ids": [
          "ca-dmv-sample-test-1",
          "ca-dmv-handbook-section-6-navigating-roads"
        ]
      },
      {
        "segment_id": "lesson_signs_signals_basics_segment_2",
        "text": "At stops, use the limit line first. If there is no limit line, stop before the crosswalk or intersection.",
        "source_ids": [
          "ca-dmv-sample-test-1",
          "ca-dmv-handbook-section-6-navigating-roads"
        ]
      },
      {
        "segment_id": "lesson_signs_signals_basics_segment_3",
        "text": "School bus yellow warning lights mean slow down and prepare to stop.",
        "source_ids": [
          "ca-dmv-sample-test-1",
          "ca-dmv-handbook-section-6-navigating-roads"
        ]
      }
    ],
    "rule_ids": [
      "signs_signals_school_bus_yellow",
      "signs_signals_red_light_right_turn",
      "signs_signals_stop_behind_limit_line"
    ],
    "source_ids": [
      "ca-dmv-sample-test-1",
      "ca-dmv-handbook-section-6-navigating-roads"
    ],
    "review_status": "draft"
  },
  {
    "lesson_id": "lesson_speed_limits_basics",
    "topic_ids": [
      "speed_limits"
    ],
    "title": "Speed Limits Basics",
    "segments": [
      {
        "segment_id": "lesson_speed_limits_basics_segment_1",
        "text": "The posted speed limit is not permission to drive that speed in every situation.",
        "source_ids": [
          "ca-dmv-handbook-section-8-safe-driving-cont2",
          "ca-dmv-sample-test-1",
          "ca-dmv-handbook-section-6-navigating-roads"
        ]
      },
      {
        "segment_id": "lesson_speed_limits_basics_segment_2",
        "text": "California's Basic Speed Law requires you to drive no faster than is safe for conditions.",
        "source_ids": [
          "ca-dmv-handbook-section-8-safe-driving-cont2",
          "ca-dmv-sample-test-1",
          "ca-dmv-handbook-section-6-navigating-roads"
        ]
      },
      {
        "segment_id": "lesson_speed_limits_basics_segment_3",
        "text": "Some situations have specific lower limits, including limited-visibility uncontrolled railroad crossings.",
        "source_ids": [
          "ca-dmv-handbook-section-8-safe-driving-cont2",
          "ca-dmv-sample-test-1",
          "ca-dmv-handbook-section-6-navigating-roads"
        ]
      }
    ],
    "rule_ids": [
      "speed_limits_basic_speed_law",
      "speed_limits_railroad_crossing_visibility",
      "speed_limits_highway_entry"
    ],
    "source_ids": [
      "ca-dmv-handbook-section-8-safe-driving-cont2",
      "ca-dmv-sample-test-1",
      "ca-dmv-handbook-section-6-navigating-roads"
    ],
    "review_status": "draft"
  },
  {
    "lesson_id": "lesson_lane_changes_turns_basics",
    "topic_ids": [
      "lane_changes_turns"
    ],
    "title": "Lane Changes and Turns Basics",
    "segments": [
      {
        "segment_id": "lesson_lane_changes_turns_basics_segment_1",
        "text": "Good turns start from the correct lane, use a signal, and finish in the proper lane.",
        "source_ids": [
          "ca-dmv-handbook-section-6-navigating-roads",
          "ca-dmv-sample-test-2",
          "ca-dmv-sample-test-1"
        ]
      },
      {
        "segment_id": "lesson_lane_changes_turns_basics_segment_2",
        "text": "Before merging or changing lanes, use mirrors, signal, and check blind spots.",
        "source_ids": [
          "ca-dmv-handbook-section-6-navigating-roads",
          "ca-dmv-sample-test-2",
          "ca-dmv-sample-test-1"
        ]
      },
      {
        "segment_id": "lesson_lane_changes_turns_basics_segment_3",
        "text": "When entering a highway, match traffic speed when possible and merge into a safe gap.",
        "source_ids": [
          "ca-dmv-handbook-section-6-navigating-roads",
          "ca-dmv-sample-test-2",
          "ca-dmv-sample-test-1"
        ]
      }
    ],
    "rule_ids": [
      "lane_changes_turns_right_turn_position",
      "lane_changes_turns_left_turn_position",
      "lane_changes_turns_signal_blind_spot",
      "right_of_way_highway_traffic"
    ],
    "source_ids": [
      "ca-dmv-handbook-section-6-navigating-roads",
      "ca-dmv-sample-test-2",
      "ca-dmv-sample-test-1"
    ],
    "review_status": "draft"
