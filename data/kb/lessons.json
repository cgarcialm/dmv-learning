  {
    "lesson_id": "lesson_safe_driving_core",
    "topic_ids": [
      "safe_driving"
    ],
    "title": "Safe Driving Core",
    "segments": [
      {
        "segment_id": "lesson_safe_driving_core_segment_1",
        "text": "Safe driving depends on space, visibility, scanning, and avoiding distractions.",
        "source_ids": [
          "ca-dmv-handbook-section-8-safe-driving",
          "ca-dmv-sample-test-2",
          "ca-dmv-sample-test-4",
          "ca-dmv-sample-test-5"
        ]
      },
      {
        "segment_id": "lesson_safe_driving_core_segment_2",
        "text": "Give large trucks and motorcycles more room because they handle and stop differently from passenger vehicles.",
        "source_ids": [
          "ca-dmv-handbook-section-8-safe-driving",
          "ca-dmv-sample-test-2",
          "ca-dmv-sample-test-4",
          "ca-dmv-sample-test-5"
        ]
      },
      {
        "segment_id": "lesson_safe_driving_core_segment_3",
        "text": "Adjust speed and following distance for rain, smoke, dust, traffic, and other conditions.",
        "source_ids": [
          "ca-dmv-handbook-section-8-safe-driving",
          "ca-dmv-sample-test-2",
          "ca-dmv-sample-test-4",
          "ca-dmv-sample-test-5"
        ]
      }
    ],
    "rule_ids": [
      "safe_driving_following_distance",
      "safe_driving_scan_road",
      "safe_driving_large_trucks_blind_spots",
      "safe_driving_rain_first_minutes"
    ],
    "source_ids": [
