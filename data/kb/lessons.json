          "ca-dmv-sample-test-1",
          "ca-dmv-sample-test-2",
          "ca-dmv-handbook-section-6-navigating-roads"
        ]
      },
      {
        "segment_id": "lesson_parking_stopping_basics_segment_2",
        "text": "Parking questions often test curb colors, hill safety, and parallel parking setup.",
        "source_ids": [
          "ca-dmv-sample-test-1",
          "ca-dmv-sample-test-2",
          "ca-dmv-handbook-section-6-navigating-roads"
        ]
      },
      {
        "segment_id": "lesson_parking_stopping_basics_segment_3",
        "text": "When parking on a hill, secure the car so it cannot roll.",
        "source_ids": [
          "ca-dmv-sample-test-1",
          "ca-dmv-sample-test-2",
          "ca-dmv-handbook-section-6-navigating-roads"
        ]
      }
    ],
