    ],
    "title": "Collisions and Emergencies",
    "segments": [
      {
        "segment_id": "lesson_collisions_emergencies_core_segment_1",
        "text": "After a collision, stop, check for injuries, exchange required information, and report when required.",
        "source_ids": [
          "ca-dmv-handbook-section-10-insurance-collisions",
          "ca-dmv-handbook-section-7-laws-road-cont1",
          "ca-dmv-sample-test-4",
          "ca-dmv-sample-test-5",
          "ca-dmv-sample-test-2",
          "ca-dmv-sample-test-3"
        ]
      },
      {
        "segment_id": "lesson_collisions_emergencies_core_segment_2",
        "text": "Never enter railroad tracks unless you can completely clear them.",
        "source_ids": [
          "ca-dmv-handbook-section-10-insurance-collisions",
          "ca-dmv-handbook-section-7-laws-road-cont1",
          "ca-dmv-sample-test-4",
          "ca-dmv-sample-test-5",
          "ca-dmv-sample-test-2",
          "ca-dmv-sample-test-3"
        ]
      },
      {
        "segment_id": "lesson_collisions_emergencies_core_segment_3",
        "text": "Some collisions require filing an SR-1 report with DMV.",
        "source_ids": [
          "ca-dmv-handbook-section-10-insurance-collisions",
          "ca-dmv-handbook-section-7-laws-road-cont1",
          "ca-dmv-sample-test-4",
