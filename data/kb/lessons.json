    "title": "Impairment Rules",
    "segments": [
      {
        "segment_id": "lesson_impaired_driving_core_segment_1",
        "text": "Alcohol and drugs can affect judgment, coordination, and reaction time.",
        "source_ids": [
          "ca-dmv-handbook-section-9-alcohol-drugs",
          "ca-dmv-sample-test-4"
        ]
      },
      {
        "segment_id": "lesson_impaired_driving_core_segment_2",
        "text": "Open alcohol containers must not be accessible to the driver or passengers.",
        "source_ids": [
          "ca-dmv-handbook-section-9-alcohol-drugs",
          "ca-dmv-sample-test-4"
        ]
      },
      {
        "segment_id": "lesson_impaired_driving_core_segment_3",
        "text": "Drivers under 21 have stricter alcohol-related rules.",
        "source_ids": [
          "ca-dmv-handbook-section-9-alcohol-drugs",
          "ca-dmv-sample-test-4"
        ]
      }
    ],
